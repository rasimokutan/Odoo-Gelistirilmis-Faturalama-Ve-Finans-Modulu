<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="partner_aging_snapshot_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="partner">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Cari Yaslandirma Ozeti</h2>
                        <p><strong>Cari:</strong> <span t-esc="partner.display_name"/></p>
                        <p><strong>Risk Seviyesi:</strong> <span t-esc="dict(partner._fields['finance_risk_level'].selection).get(partner.finance_risk_level, '-')"/></p>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Toplam Alacak</th>
                                    <th>Toplam Borc</th>
                                    <th>Gecikmis Tutar</th>
                                    <th>0-30</th>
                                    <th>31-60</th>
                                    <th>61-90</th>
                                    <th>90+</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-esc="partner.finance_total_receivable"/></td>
                                    <td><span t-esc="partner.finance_total_payable"/></td>
                                    <td><span t-esc="partner.finance_overdue_amount"/></td>
                                    <td><span t-esc="partner.finance_age_0_30"/></td>
                                    <td><span t-esc="partner.finance_age_31_60"/></td>
                                    <td><span t-esc="partner.finance_age_61_90"/></td>
                                    <td><span t-esc="partner.finance_age_90_plus"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
