<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="privilege_enhanced_finance" model="res.groups.privilege">
            <field name="name">Gelismis Finans</field>
            <field name="description">Operasyonel finans ve gelismis muhasebe yetkileri.</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="sequence">120</field>
        </record>

        <record id="group_enhanced_finance_user" model="res.groups">
            <field name="name">Gelismis Finans Kullanicisi</field>
            <field name="privilege_id" ref="enhanced_invoicing_accounting.privilege_enhanced_finance"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
            <field name="implied_by_ids" eval="[(4, ref('account.group_account_invoice')), (4, ref('account.group_account_user')), (4, ref('account.group_account_readonly')), (4, ref('account.group_account_manager'))]"/>
        </record>

        <record id="group_enhanced_finance_manager" model="res.groups">
            <field name="name">Gelismis Finans Yoneticisi</field>
            <field name="privilege_id" ref="enhanced_invoicing_accounting.privilege_enhanced_finance"/>
            <field name="implied_ids" eval="[(4, ref('enhanced_invoicing_accounting.group_enhanced_finance_user')), (4, ref('account.group_account_manager'))]"/>
            <field name="implied_by_ids" eval="[(4, ref('account.group_account_manager'))]"/>
        </record>

        <record id="rule_followup_user_company" model="ir.rule">
            <field name="name">Gelismis Takip Sirket Erisimi</field>
            <field name="model_id" ref="model_enhanced_finance_followup_log"/>
            <field name="groups" eval="[(4, ref('enhanced_invoicing_accounting.group_enhanced_finance_user'))]"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

