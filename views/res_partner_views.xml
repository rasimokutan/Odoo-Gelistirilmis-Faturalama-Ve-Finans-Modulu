<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_enhanced_finance" model="ir.ui.view">
            <field name="name">res.partner.form.enhanced.finance</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.view_partner_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_finance_followups" type="object" class="oe_stat_button" icon="fa-bell" groups="enhanced_invoicing_accounting.group_enhanced_finance_user">
                        <field name="finance_followup_count" widget="statinfo" string="Takipler"/>
                    </button>
                    <button name="action_open_partner_aging_report" type="object" class="oe_stat_button" icon="fa-line-chart" groups="enhanced_invoicing_accounting.group_enhanced_finance_user">
                        <span class="o_stat_text">Yaslandirma</span>
                    </button>
                </xpath>
                <xpath expr="//page[@name='sales_purchases']" position="after">
                    <page string="Finans Ozeti" name="enhanced_finance_summary" groups="enhanced_invoicing_accounting.group_enhanced_finance_user">
                        <group>
                            <group string="Ozet">
                                <field name="company_currency_id" invisible="1"/>
                                <field name="finance_total_receivable" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                                <field name="finance_total_payable" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                                <field name="finance_overdue_amount" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                                <field name="finance_overdue_count"/>
                                <field name="finance_paid_on_time_rate" widget="percentage"/>
                            </group>
                            <group string="Risk">
                                <field name="finance_risk_score"/>
                                <field name="finance_risk_level" widget="badge" decoration-danger="finance_risk_level == 'high'" decoration-warning="finance_risk_level == 'medium'" decoration-success="finance_risk_level == 'low'"/>
                                <field name="finance_summary_note" nolabel="1" readonly="1"/>
                            </group>
                        </group>
                        <group string="Yaslandirma Dilimleri">
                            <field name="finance_age_0_30" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                            <field name="finance_age_31_60" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                            <field name="finance_age_61_90" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                            <field name="finance_age_90_plus" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                        </group>
                        <group string="Takip Gecmisi">
                            <field name="finance_followup_log_ids" nolabel="1">
                                <list create="0" delete="0">
                                    <field name="name"/>
                                    <field name="invoice_id"/>
                                    <field name="due_date"/>
                                    <field name="overdue_days"/>
                                    <field name="reminder_level"/>
                                    <field name="sent_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
