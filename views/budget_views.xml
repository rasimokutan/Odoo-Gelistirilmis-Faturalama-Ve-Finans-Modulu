<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_enhanced_finance_budget_list" model="ir.ui.view">
            <field name="name">enhanced.finance.budget.list</field>
            <field name="model">enhanced.finance.budget</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="state"/>
                    <field name="total_planned_amount"/>
                    <field name="total_practical_amount"/>
                    <field name="over_budget_count"/>
                </list>
            </field>
        </record>

        <record id="view_enhanced_finance_budget_form" model="ir.ui.view">
            <field name="name">enhanced.finance.budget.form</field>
            <field name="model">enhanced.finance.budget</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" string="Onayla" type="object" class="oe_highlight" groups="enhanced_invoicing_accounting.group_enhanced_finance_manager" invisible="state != 'draft'"/>
                        <button name="action_reset_draft" string="Taslaga Don" type="object" invisible="state == 'draft'"/>
                        <button name="action_close" string="Kapat" type="object" groups="enhanced_invoicing_accounting.group_enhanced_finance_manager" invisible="state != 'confirmed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,closed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                        </group>
                        <group string="Ozet">
                            <field name="total_planned_amount"/>
                            <field name="total_practical_amount"/>
                            <field name="over_budget_count"/>
                        </group>
                        <notebook>
                            <page string="Butce Satirlari">
                                <field name="line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="analytic_account_id"/>
                                        <field name="account_id"/>
                                        <field name="planned_amount"/>
                                        <field name="practical_amount" readonly="1"/>
                                        <field name="achievement_rate" widget="percentage" readonly="1"/>
                                        <field name="is_over_budget"/>
                                        <field name="warning_message"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_enhanced_finance_budget_search" model="ir.ui.view">
            <field name="name">enhanced.finance.budget.search</field>
            <field name="model">enhanced.finance.budget</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="company_id"/>
                    <filter string="Taslak" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Onayli" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter string="Kapali" name="closed" domain="[('state', '=', 'closed')]"/>
                    <group>
                        <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_enhanced_finance_budget_line_pivot" model="ir.ui.view">
            <field name="name">enhanced.finance.budget.line.pivot</field>
            <field name="model">enhanced.finance.budget.line</field>
            <field name="arch" type="xml">
                <pivot string="Butce Satirlari">
                    <field name="company_id" type="row"/>
                    <field name="analytic_account_id" type="row"/>
                    <field name="account_id" type="col"/>
                    <field name="planned_amount" type="measure"/>
                    <field name="practical_amount" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_enhanced_finance_budget" model="ir.actions.act_window">
            <field name="name">Butceler</field>
            <field name="res_model">enhanced.finance.budget</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="search_view_id" ref="view_enhanced_finance_budget_search"/>
        </record>
    </data>
</odoo>
