<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_generate_finance_followups" model="ir.cron">
            <field name="name">Gecikmis Finans Takiplerini Olustur</field>
            <field name="model_id" ref="model_enhanced_finance_followup_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_overdue_followups()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_mark_bank_exceptions" model="ir.cron">
            <field name="name">Yuksek Tutarlari Banka Istisnalarini Isle</field>
            <field name="model_id" ref="model_enhanced_bank_reconciliation_line"/>
            <field name="state">code</field>
            <field name="code">model.cron_mark_bank_exceptions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_budget_overrun_notice" model="ir.cron">
            <field name="name">Butce Asim Bildirimi</field>
            <field name="model_id" ref="model_enhanced_finance_budget_line"/>
            <field name="state">code</field>
            <field name="code">model.cron_budget_overrun_notice()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
